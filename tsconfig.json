{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "paths": {
      "$public/*": ["./public/*"],
      "$layouts/*": ["./src/layouts/*"],
      "$styles/*": ["./src/styles/*"],
      "$components/*": ["./src/components/*"],
      "$/*": ["./src/*"]
    }
  }
}
