---
import Game from "$components/funbox/wordle-solver/game.svelte";
import Base from "$layouts/base.astro";
---

<Base title="Wordle Solver">
  <h1 class="relative p-8 text-center text-2xl font-black italic md:text-5xl">
    <ruby>
      <rb class="drop-shadow-[2px_2px] drop-shadow-amber-600/30">
        <span class="text-amber-800">Wordle</span> Solver
      </rb>
      <rt class="text-lg md:text-2xl">The</rt>
    </ruby>

    <aside
      class="absolute top-4 right-4 flex aspect-square h-36 w-36 rotate-12 items-center justify-center rounded-full bg-amber-300 p-3.5 text-center text-lg">
      <span class="drop-shadow-[2px_2px] drop-shadow-amber-600/30">
        Now with 100% more words!
      </span>
    </aside>
  </h1>
  <Game client:only />
</Base>
