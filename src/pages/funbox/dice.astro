---
import Boilerplate from '$layouts/boiler.astro'
---

<Boilerplate title="It's your lucky day!">
    <main class="w-screen h-screen flex flex-col items-center justify-center p-9 text-center">
        <a id="fortune"></a>
        <a href="/funbox/dice" class="font-black p-4"><span class="text-black">reroll 🎲?</span></a>
    </main>
</Boilerplate>

<script>
    let fortune_elem: HTMLAnchorElement = document.getElementById('fortune')! as HTMLAnchorElement;

    let fortunes = [
        {
            href: "/funbox/groupulator",
            text: "Normally, I don't condone gambling... but it seems you took a calculated risk 🧮..."
        },
        {
            href: "/funbox/mouse",
            text: "Mahmoud Mouse-y? 🐁"
        },
        {
            href: "/funbox/dice",
            text: "They say if you keep rolling the dice, you may encounter some fun things... 🎈"
        }
    ]

    let fortune_length = fortunes.length;
    let lucky_number = Math.floor(Math.random() * fortune_length);
    let lucky_fortune = fortunes[lucky_number];

    fortune_elem.href = lucky_fortune.href;
    fortune_elem.innerText = lucky_fortune.text;
</script>