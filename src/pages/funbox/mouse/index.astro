---
import BaseLayout from "$layouts/base.astro";
import Maze from "$/pages/funbox/mouse/maze.astro";

export const prerender = false;
Astro.response.headers.set("Cache-Control", "no-cache");
---

<BaseLayout title="Get him the cheese, please!">
  <main class="flex flex-col gap-4 p-4">
    <p>
      Poor little fella just wants the cheese... but he's trapped in a multi-player, real-time cheese maze synchronizes
      with everyone who is currently viewing the website. 🥺
    </p>

    <aside class="border-l-4 pl-2">
      How to play the game:
      <ul class="list-outside list-disc pl-4">
        <li>
          <b>Use the arrows at the bottom of the page</b> (⬆️⬇️⬅️➡️) to move the mouse (🐁).
        </li>
        <li>Get the mouse to the Cheese (🧀) to win.</li>
        <li>Get keys (🗝️) to unlock doors (🚪).</li>
        <li>Don't run into walls (⬛)</li>
      </ul>
    </aside>

    <Maze />

    <div class="mx-auto flex w-fit flex-col items-center justify-stretch gap-3 bg-slate-200 p-5 font-mono">
      <nav class="grid grid-cols-3 grid-rows-3 gap-1 *:cursor-pointer">
        <button
          class="col-start-2 row-start-1 aspect-square border-4 border-amber-700"
          hx-post="/funbox/mouse/maze"
          hx-swap="none"
          hx-include="this">
          ⬆️
          <input type="hidden" name="direction" value="up" />
        </button>
        <button
          class="col-start-3 row-start-2 aspect-square border-4 border-amber-700"
          hx-post="/funbox/mouse/maze"
          hx-swap="none"
          hx-include="this">
          ➡️
          <input type="hidden" name="direction" value="right" />
        </button>
        <button
          class="col-start-2 row-start-3 aspect-square border-4 border-amber-700"
          hx-post="/funbox/mouse/maze"
          hx-swap="none"
          hx-include="this">
          ⬇️
          <input type="hidden" name="direction" value="down" />
        </button>
        <button
          class="col-start-1 row-start-2 aspect-square border-4 border-amber-700"
          hx-post="/funbox/mouse/maze"
          hx-swap="none"
          hx-include="this">
          ⬅️
          <input type="hidden" name="direction" value="left" />
        </button>
      </nav>
      <button
        class="cursor-pointer border-4 border-amber-700 bg-amber-700 p-2 font-black text-white"
        hx-post="/funbox/mouse/regenerate"
        hx-swap="none">
        Regenerate <span class="text-nowrap">Maze 🔄</span>️
      </button>
      <h6 class="text-center font-bold">
        Mouse <br />Mind-Control <br />Apparatus 6000 🤖
      </h6>
    </div>
  </main>
</BaseLayout>

<script>
  import "htmx.org";
  import "htmx-ext-sse";
</script>
