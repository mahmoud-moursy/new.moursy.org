---
import Font from "astro/components/Font.astro";
import "$styles/global.css";

interface Props {
    title?: string;
}

const { title }: Props = Astro.props;
---

<html lang="en">
<head>
    <Font cssVariable='--ancizar-serif' preload />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="application/svg" href="/Flower.svg" />
    <title>{title || "Moursy's Website"}</title>
</head>
<body class="flex flex-col md:items-center md:justify-center md:py-8 w-screen min-h-screen overflow-x-hidden">
    <slot />
</body>
</html>
